<!--
  Application root definition for Avalonia.

  Theme: Semi.Avalonia (SemiTheme + DataGridSemiTheme)
  Theme variant: Default (follows OS light/dark setting).

  SemiTheme locale is synchronized with LocalizationService.CurrentLanguage
  in App.axaml.cs so that built-in control strings change language accordingly.
-->
<Application x:Class="WeinBatchUpdate.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:WeinBatchUpdate"
             xmlns:semi="https://irihi.tech/semi"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <semi:SemiTheme />
        <semi:DataGridSemiTheme />
    </Application.Styles>
</Application>
